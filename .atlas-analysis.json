  "keyFeatures": [
    "Segment-based leadership rotation for automatic load balancing",
    "Raft consensus for fault-tolerant metadata coordination",
    "Lease-based write fencing to prevent split-brain",
    "High-performance storage with io_uring on Linux",
    "Batch operations with atomic guarantees",
    "Configurable consistency models (strict and relaxed)",
    "TCP client protocol with auto-forwarding"
  ],
  "publicApiSurface": [
    "Walrus::new() - Create WAL instance",
    "Walrus::append_for_topic() - Write to topic",
    "Walrus::read_next() - Read from topic",
    "Walrus::batch_append_for_topic() - Atomic batch writes",
    "Walrus::batch_read_for_topic() - Batch reads",
    "REGISTER <topic> - Create topic",
    "PUT <topic> <payload> - Append message",
    "GET <topic> - Read message",
    "STATE <topic> - Get topic metadata",
    "METRICS - Get cluster metrics"
  ]
